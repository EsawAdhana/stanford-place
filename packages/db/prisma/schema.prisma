generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  googleSub    String        @unique
  email        String        @unique
  displayName  String?
  image        String?
  isAdmin      Boolean       @default(false)
  nextPlaceAt  DateTime?
  createdAt    DateTime      @default(now())
  lastSeenAt   DateTime      @default(now())
  placements   Placement[]
  suspensions  Suspension[]
  currentEdits CurrentPixel[] @relation("CurrentPixelUpdatedBy")
}

model Placement {
  id            BigInt   @id @default(autoincrement())
  userId        String   @db.Uuid
  x             Int
  y             Int
  color         Int
  placedAt      DateTime @default(now())
  ipHash        String?
  userAgentHash String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, placedAt(sort: Desc)])
  @@index([x, y, placedAt(sort: Desc)])
}

model CurrentPixel {
  x         Int
  y         Int
  color     Int
  updatedAt DateTime @default(now())
  updatedBy String   @db.Uuid
  user      User     @relation("CurrentPixelUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)

  @@id([x, y])
  @@index([updatedAt(sort: Desc)])
}

model Suspension {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  reason     String
  startsAt   DateTime  @default(now())
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
}
